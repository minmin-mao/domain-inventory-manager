generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Domain {
  id             String       @id @default(cuid())
  domain         String       @unique
  hosting        String
  account        String
  project        String
  country        String
  language       String?
  expiry         DateTime?
  reservedAt     DateTime?
  reservedForProject String?
  reservedForCountry String?
  reservedForPic String?
  usedAt         DateTime?
  usedForProject String?
  usedForCountry String?
  usedForPic     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  status         DomainStatus

  @@index([status, createdAt])
  @@index([project])
  @@index([country])
  @@index([hosting])
  @@index([expiry])
  @@index([usedForCountry, usedForPic, usedAt])
  @@index([status, reservedAt])
}

model DomainHistory {
  id         String    @id @default(cuid())
  domainId   String
  domain     String
  hosting    String
  expiry     DateTime?
  project    String
  country    String
  usedForPic String?
  createdAt  DateTime  @default(now())

  @@index([domainId])
  @@index([createdAt])
  @@index([project])
  @@index([country])
  @@index([hosting])
  @@index([expiry])
  @@index([country, usedForPic, createdAt])
}

enum DomainStatus {
  available
  reserved
  taken
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Domain {
  id             String       @id @default(cuid())
  domain         String       @unique
  hosting        String
  account        String
  project        String
  country        String
  expiry         DateTime?
  usedAt         DateTime?
  usedForProject String?
  usedForCountry String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  status         DomainStatus

  @@index([status, createdAt])
  @@index([project])
  @@index([country])
  @@index([hosting])
  @@index([expiry])
}

model DomainHistory {
  id        String   @id @default(cuid())
  domainId  String
  domain    String
  hosting   String
  expiry    DateTime?
  project   String
  country   String
  createdAt DateTime @default(now())

  @@index([domainId])
  @@index([createdAt])
  @@index([project])
  @@index([country])
  @@index([hosting])
  @@index([expiry])
}

enum DomainStatus {
  available
  taken
}
